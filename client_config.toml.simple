# ==============================================================================
# MasterDnsVPN Go Client Configuration (Sample)
# Profile: high-loss / high-latency / many resolvers / small MTU
# ==============================================================================

# ------------------------------------------------------------------------------
# 1) Tunnel Identity & Security
# ------------------------------------------------------------------------------

# Must match server DOMAIN values.
DOMAINS = ["v.domain.com"]

# 0=None, 1=XOR, 2=ChaCha20, 3=AES-128-GCM, 4=AES-192-GCM, 5=AES-256-GCM
DATA_ENCRYPTION_METHOD = 1

# Must match server encryption key.
ENCRYPTION_KEY = ""

# ------------------------------------------------------------------------------
# 2) Local Listener
# ------------------------------------------------------------------------------

# Local client listener.
# SOCKS5 is the primary mode. TCP is raw tunnel mode.
PROTOCOL_TYPE = "SOCKS5"
LISTEN_IP = "127.0.0.1"
LISTEN_PORT = 18000

# Protect the local SOCKS5 listener if needed.
SOCKS5_AUTH = false
SOCKS5_USER = "master_dns_vpn"
SOCKS5_PASS = "master_dns_vpn"

# ------------------------------------------------------------------------------
# 3) Local DNS
# ------------------------------------------------------------------------------

LOCAL_DNS_ENABLED = false
LOCAL_DNS_IP = "127.0.0.1"
LOCAL_DNS_PORT = 53

LOCAL_DNS_CACHE_MAX_RECORDS = 10000
LOCAL_DNS_CACHE_TTL_SECONDS = 14400.0
LOCAL_DNS_PENDING_TIMEOUT_SECONDS = 300.0
# How long fragmented DNS tunnel responses are kept while waiting to complete.
DNS_RESPONSE_FRAGMENT_TIMEOUT_SECONDS = 10.0
LOCAL_DNS_CACHE_PERSIST_TO_FILE = true
LOCAL_DNS_CACHE_FLUSH_INTERVAL_SECONDS = 60.0

# ------------------------------------------------------------------------------
# 4) Resolver Strategy & Reliability
# ------------------------------------------------------------------------------

# 0=Round Robin, 1=Random, 2=Round Robin, 3=Least Loss, 4=Lowest Latency
RESOLVER_BALANCING_STRATEGY = 0

# Profile tuned for very lossy links with many resolvers.
PACKET_DUPLICATION_COUNT = 2
SETUP_PACKET_DUPLICATION_COUNT = 2

# DATA/RESEND stick to a preferred resolver per stream.
# If too many resend rounds hit the same resolver, the preferred resolver can fail over.
STREAM_RESOLVER_FAILOVER_RESEND_THRESHOLD = 2
STREAM_RESOLVER_FAILOVER_COOLDOWN = 1.0

# Background resolver health management.
# Inactive resolvers from MTU scan are rechecked in the background using the synced MTUs.
RECHECK_INACTIVE_SERVERS_ENABLED = true
RECHECK_INACTIVE_INTERVAL_SECONDS = 300.0
RECHECK_SERVER_INTERVAL_SECONDS = 3.0
RECHECK_BATCH_SIZE = 5

# If a resolver only times out across this whole window, disable it at runtime.
AUTO_DISABLE_TIMEOUT_SERVERS = true
AUTO_DISABLE_TIMEOUT_WINDOW_SECONDS = 120.0
AUTO_DISABLE_MIN_OBSERVATIONS = 6
AUTO_DISABLE_CHECK_INTERVAL_SECONDS = 3.0

# Some DNS paths behave better with base-encoded labels. Keep false unless needed.
BASE_ENCODE_DATA = false

# ------------------------------------------------------------------------------
# 5) Compression
# ------------------------------------------------------------------------------

# 0=OFF, 1=ZSTD, 2=LZ4, 3=ZLIB
UPLOAD_COMPRESSION_TYPE = 0
DOWNLOAD_COMPRESSION_TYPE = 0
COMPRESSION_MIN_SIZE = 128

# ------------------------------------------------------------------------------
# 6) MTU Discovery
# ------------------------------------------------------------------------------

# This sample is tuned for very small MTUs similar to your stress scenario.
MIN_UPLOAD_MTU = 40
MAX_UPLOAD_MTU = 150

MIN_DOWNLOAD_MTU = 100
MAX_DOWNLOAD_MTU = 500

MTU_TEST_RETRIES = 2
MTU_TEST_TIMEOUT = 2.0
MTU_TEST_PARALLELISM = 24

SAVE_MTU_SERVERS_TO_FILE = false
MTU_SERVERS_FILE_NAME = "masterdnsvpn_success_test_{time}.log"
MTU_SERVERS_FILE_FORMAT = "{IP} - UP: {UP_MTU} DOWN: {DOWN-MTU}"
MTU_USING_SECTION_SEPARATOR_TEXT = ""
MTU_REMOVED_SERVER_LOG_FORMAT = "Resolver {IP} removed at {TIME} due to {CAUSE}"
MTU_ADDED_SERVER_LOG_FORMAT = "Resolver {IP} added back at {TIME} (UP {UP_MTU}, DOWN {DOWN_MTU})"

# ------------------------------------------------------------------------------
# 7) Client Runtime Sizing
# ------------------------------------------------------------------------------

# Async runtime workers and queue sizes.
TUNNEL_READER_WORKERS = 8
TUNNEL_WRITER_WORKERS = 8
TUNNEL_PROCESS_WORKERS = 6
TUNNEL_PACKET_TIMEOUT_SECONDS = 10.0
DISPATCHER_IDLE_POLL_INTERVAL_SECONDS = 0.020
TX_CHANNEL_SIZE = 8192
RX_CHANNEL_SIZE = 8192

# Async cleanup / local socket timeouts.
SOCKS_UDP_ASSOCIATE_READ_TIMEOUT_SECONDS = 30.0
CLIENT_TERMINAL_STREAM_RETENTION_SECONDS = 45.0
CLIENT_CANCELLED_SETUP_RETENTION_SECONDS = 120.0

# Session retry profile.
SESSION_INIT_RETRY_BASE_SECONDS = 1.0
SESSION_INIT_RETRY_STEP_SECONDS = 1.0
SESSION_INIT_RETRY_LINEAR_AFTER = 5
SESSION_INIT_RETRY_MAX_SECONDS = 60.0
SESSION_INIT_BUSY_RETRY_INTERVAL_SECONDS = 60.0

# Ping / keepalive pacing.
PING_AGGRESSIVE_INTERVAL_SECONDS = 0.300
PING_LAZY_INTERVAL_SECONDS = 1.0
PING_COOLDOWN_INTERVAL_SECONDS = 3.0
PING_COLD_INTERVAL_SECONDS = 30.0
PING_WARM_THRESHOLD_SECONDS = 5.0
PING_COOL_THRESHOLD_SECONDS = 10.0
PING_COLD_THRESHOLD_SECONDS = 20.0

# Per-resolver UDP connection reuse pool.
RESOLVER_UDP_CONNECTION_POOL_SIZE = 128

# Initial queue/store capacities to reduce reallocations under many active streams.
STREAM_QUEUE_INITIAL_CAPACITY = 256
ORPHAN_QUEUE_INITIAL_CAPACITY = 64
DNS_RESPONSE_FRAGMENT_STORE_CAPACITY = 512

# ------------------------------------------------------------------------------
# 8) ARQ & Packing
# ------------------------------------------------------------------------------

MAX_PACKETS_PER_BATCH = 5

ARQ_WINDOW_SIZE = 600
ARQ_INITIAL_RTO_SECONDS = 0.5
ARQ_MAX_RTO_SECONDS = 6.0
ARQ_CONTROL_INITIAL_RTO_SECONDS = 0.5
ARQ_CONTROL_MAX_RTO_SECONDS = 6.0
ARQ_MAX_CONTROL_RETRIES = 120
ARQ_INACTIVITY_TIMEOUT_SECONDS = 1800.0
ARQ_DATA_PACKET_TTL_SECONDS = 2400.0
ARQ_CONTROL_PACKET_TTL_SECONDS = 1200.0
ARQ_MAX_DATA_RETRIES = 1200
ARQ_TERMINAL_DRAIN_TIMEOUT_SECONDS = 120.0
ARQ_TERMINAL_ACK_WAIT_TIMEOUT_SECONDS = 90.0

# ------------------------------------------------------------------------------
# 9) Logging
# ------------------------------------------------------------------------------

LOG_LEVEL = "INFO"
